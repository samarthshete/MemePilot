# ChadWallet Web — environment variables
# Copy to .env.local and fill in. .env.local is gitignored; this template is committed.
#
# RULE (CLAUDE.md hard rule 1): anything NOT prefixed with NEXT_PUBLIC_ is a SECRET
# and is server-only. Never reference a non-public var from client code.

# ── Server-only secrets (never sent to the browser) ───────────────────────────
# Privy app secret — verifies Privy access tokens server-side (Stage 3).
PRIVY_APP_SECRET=
# BirdEye API key — market data proxy (Stage 2+). Free tier ~30K CU/mo.
BIRDEYE_API_KEY=
# Alchemy (or other KEYED) Solana mainnet RPC — send tx / read balances (Stage 6).
# Embeds a secret in the URL → keep it HERE (server-only), NEVER in NEXT_PUBLIC_*.
SOLANA_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/YOUR_KEY
# Jupiter API key — swap quote/build (Stage 6).
JUPITER_API_KEY=
# Supabase — account/portfolio persistence (Phase C-2). Service-role key bypasses
# RLS; server-only, NEVER expose to the client. Run docs/supabase-schema.sql once.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Public (NEXT_PUBLIC_*) — safe to ship to the browser ──────────────────────
# Privy App ID (public identifier, not the secret).
NEXT_PUBLIC_PRIVY_APP_ID=
# Canonical site URL, e.g. https://memepilot.app
NEXT_PUBLIC_SITE_URL=
# KEYLESS/public Solana RPC only — ships to the browser (Privy client config).
# Must NOT be an Alchemy /v2/<key> or ?api-key= URL (a startup guard throws if it is).
# Put keyed RPCs in the server-only SOLANA_RPC_URL above.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# App Store / Google Play download links (landing CTAs). If unset, the app falls
# back to these canonical URLs. Play package id is `xyz.chadwallet.www` (the bare
# `xyz.chadwallet` 404s).
NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/us/app/chadwallet/id6757367474
NEXT_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=xyz.chadwallet.www
